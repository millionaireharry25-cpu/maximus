{
  "entities": {
    "Ad": {
      "title": "Ad",
      "description": "An advertisement to be shown to users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "intervalMinutes": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "content", "intervalMinutes", "isActive", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent between admin and users",
      "type": "object",
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["from", "to", "subject", "body", "timestamp"]
    },
    "UserMeta": {
      "title": "UserMeta",
      "description": "User specific metadata like read and deleted messages",
      "type": "object",
      "properties": {
        "readMessages": { "type": "array", "items": { "type": "string" } },
        "deletedMessages": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["admin", "user"] }
      }
    }
  },
  "firestore": {
    "/ads/{adId}": {
      "schema": { "$ref": "#/entities/Ad" },
      "description": "Global advertisements"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages between admin and users"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserMeta" },
      "description": "User metadata"
    }
  }
}
